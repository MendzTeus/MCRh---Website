generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MediaType {
  IMAGE
  VIDEO
}

enum EnquiryType {
  LETTINGS
  MANAGEMENT
  GENERAL
}

enum UserRole {
  ADMIN
}

model Property {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  area        String?
  headline    String?
  description String
  bedrooms    Int?
  beds        Int?
  bathrooms   Int?
  maxGuests   Int?
  amenities   String[] @default([])
  airbnbUrl   String?

  displayOrder Int     @default(0)
  published    Boolean @default(false)
  icalFeedUrl  String?

  media        MediaAsset[]
  blockedDates BlockedDate[]
  enquiries    Enquiry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MediaAsset {
  id         String    @id @default(cuid())
  propertyId String
  property   Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  type       MediaType
  path       String
  alt        String
  order      Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
}

model BlockedDate {
  id         String   @id @default(cuid())
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  start      DateTime
  end        DateTime
  source     String
  syncedAt   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([propertyId])
  @@index([start, end])
}

model Enquiry {
  id         String      @id @default(cuid())
  type       EnquiryType
  name       String
  email      String
  phone      String?
  message    String
  propertyId String?
  property   Property?   @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([type])
  @@index([propertyId])
  @@index([createdAt])
}

model Service {
  id           String  @id @default(cuid())
  slug         String  @unique
  title        String
  body         String
  displayOrder Int     @default(0)
  published    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      UserRole @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
